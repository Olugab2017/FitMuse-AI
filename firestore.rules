rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global authentication and identity helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. User profile data validation helper
    function isValidUserProfile(data) {
      return (!('name' in data) || (data.name is string && data.name.size() <= 100))
        && (!('email' in data) || (data.email is string && data.email.size() <= 150))
        && (!('avatarUrl' in data) || data.avatarUrl == null || (data.avatarUrl is string && data.avatarUrl.size() <= 2083))
        && (!('styleProfile' in data) || data.styleProfile == null || data.styleProfile is map)
        && (!('orderHistory' in data) || data.orderHistory == null || data.orderHistory is list);
    }

    // 4. Secure direct path matches
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming());
      allow delete: if isOwner(userId);
    }

    match /test/connection {
      allow get: if true;
    }
  }
}
